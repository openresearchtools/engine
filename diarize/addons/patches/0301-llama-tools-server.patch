+                i += 3;
+                continue;
+            }
+        }
+
+        if (c0 == 0xF0 && i + 3 < n) {
+            const unsigned char c1 = (unsigned char) text[i + 1];
+            const unsigned char c2 = (unsigned char) text[i + 2];
+            const unsigned char c3 = (unsigned char) text[i + 3];
+            if (c1 >= 0x90 && c1 <= 0xBF &&
+                srv_audio_is_utf8_continuation(c2) &&

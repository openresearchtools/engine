+static std::string now_timestamp() {
+    const std::time_t t = std::time(nullptr);
+    std::tm tmv{};
+#if defined(_WIN32)
+    localtime_s(&tmv, &t);
+#else
+    localtime_r(&t, &tmv);
+#endif
+    char buf[64] = {0};
+    std::strftime(buf, sizeof(buf), "%Y%m%d_%H%M%S", &tmv);

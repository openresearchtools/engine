+// Minimal dependency from whisper.cpp examples/common.h used by cli.cpp.
+bool is_file_exist(const char * filename) {
+    if (filename == nullptr || filename[0] == '\0') {
+        return false;
+    }
+    std::ifstream ifs(filename, std::ios::binary);
+    return ifs.good();

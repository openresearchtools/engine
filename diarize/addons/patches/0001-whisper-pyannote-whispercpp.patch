+static bool env_flag_enabled(const char * name) {
+    const char * v = std::getenv(name);
+    if (v == nullptr) {
+        return false;
+    }
+    const std::string s = to_lower_copy(std::string(v));
+    return s == "1" || s == "true" || s == "yes" || s == "on";
+}

+static std::string srv_audio_clean_cache_name(const std::string & name) {
+    std::string out;
+    out.reserve(name.size());
+    for (const unsigned char c : name) {
+        if (std::isalnum(c) || c == '.' || c == '_' || c == '-') {
+            out.push_back((char) c);
+        } else {
+            out.push_back('_');
+        }
+    }
+    return out;
+}

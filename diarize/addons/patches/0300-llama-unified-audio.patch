+static std::string srv_audio_shell_quote(const std::string & s) {
+    std::string out = "\"";
+    out.reserve(s.size() + 2);
+    for (char c : s) {
+        if (c == '"') {
+            out += "\\\"";
+        } else {
+            out.push_back(c);
+        }
+    }
+    out.push_back('"');
+    return out;
+}
